ConnectionStrings__IdentityConnection=Host=DB_HOST;Port=5432;Database=DB_NAME;Username=DB_USER;Password=DB_PASSWORD;Pooling=true;Maximum Pool Size=50;Timeout=15;Command Timeout=30;SSL Mode=Require;Trust Server Certificate=true
ConnectionStrings__NotificationConnection=Host=DB_HOST;Port=5432;Database=DB_NAME;Username=DB_USER;Password=DB_PASSWORD;Pooling=true;Maximum Pool Size=50;Timeout=15;Command Timeout=30;SSL Mode=Require;Trust Server Certificate=true
Messaging__RabbitMq__Uri=amqp://RABBITMQ_USER:RABBITMQ_PASSWORD@RABBITMQ_HOST:5672/
InvitationDelivery__Provider=smtp
InvitationDelivery__SmtpHost=SMTP_HOST
InvitationDelivery__SmtpPort=587
InvitationDelivery__SmtpUseStartTls=true
InvitationDelivery__SmtpUserName=SMTP_USERNAME
InvitationDelivery__SmtpPassword=SMTP_PASSWORD
InvitationDelivery__SenderAddress=no-reply@example.com
InvitationDelivery__SenderName=Norge360
InvitationDelivery__DisableDelivery=false
Notification__RabbitMq__Username=RABBITMQ_USER
Notification__RabbitMq__Password=RABBITMQ_PASSWORD
Notification__Email__Smtp__Host=SMTP_HOST
Notification__Email__Smtp__Port=587
Notification__Email__Smtp__UserName=SMTP_USERNAME
Notification__Email__Smtp__Password=SMTP_PASSWORD
Notification__Email__Smtp__FromAddress=no-reply@example.com
Notification__Email__Smtp__FromName=Norge360 Notifications
Notification__Email__Smtp__UseStartTls=true

# Frontend -> internal API routing (Next.js server-side proxy target)
# Browser calls must stay relative: /api/...
INTERNAL_API_GATEWAY_URL=http://INTERNAL_GATEWAY_HOST:8080
NEXT_PUBLIC_API_BASE_PATH=/api
